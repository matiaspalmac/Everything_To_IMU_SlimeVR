<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime"
                    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <!-- Spacing -->
    <sys:Double x:Key="SpaceXS">4</sys:Double>
    <sys:Double x:Key="SpaceS">8</sys:Double>
    <sys:Double x:Key="SpaceM">12</sys:Double>
    <sys:Double x:Key="SpaceL">16</sys:Double>
    <sys:Double x:Key="SpaceXL">24</sys:Double>
    <sys:Double x:Key="SpaceXXL">32</sys:Double>

    <!-- Padding tokens -->
    <Thickness x:Key="CardPadding">16</Thickness>
    <Thickness x:Key="CardPaddingCompact">12,10</Thickness>
    <Thickness x:Key="CardPaddingDense">8,6</Thickness>

    <!-- Typography -->
    <FontFamily x:Key="UiFontFamily">Segoe UI Variable, Segoe UI</FontFamily>
    <FontFamily x:Key="MonoFontFamily">Cascadia Mono, Consolas</FontFamily>

    <Style x:Key="MonoTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource MonoFontFamily}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <!-- Data-dense typography -->
    <Style x:Key="DataPageHeader" TargetType="TextBlock">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="Margin" Value="0,0,0,10" />
    </Style>

    <Style x:Key="DataLabel" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="DataValue" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource MonoFontFamily}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="TextAlignment" Value="Right" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="Typography.NumeralAlignment" Value="Tabular" />
    </Style>

    <Style x:Key="DataUnit" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="{DynamicResource TextTertiaryBrush}" />
        <Setter Property="Opacity" Value="0.8" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- Cards -->
    <Style x:Key="CardStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource SurfaceL2Brush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource StrokeSubtleBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="{StaticResource CardPadding}" />
    </Style>

    <Style x:Key="CardCompact" TargetType="Border" BasedOn="{StaticResource CardStyle}">
        <Setter Property="Padding" Value="{StaticResource CardPaddingCompact}" />
    </Style>

    <Style x:Key="CardDense" TargetType="Border" BasedOn="{StaticResource CardStyle}">
        <Setter Property="Padding" Value="{StaticResource CardPaddingDense}" />
    </Style>

    <Style x:Key="StatusDotStyle" TargetType="Ellipse">
        <Setter Property="Width" Value="10" />
        <Setter Property="Height" Value="10" />
    </Style>

    <!-- Button sizing tokens. Each derives from the WPF-UI default ui:Button style so they
         inherit the Fluent template (background brush, rounded corners, hover/pressed states).
         Without BasedOn the buttons lose the template entirely and render as invisible
         text-only widgets on Mica — which is what produced the "horrible buttons" artefact
         where Rescan / Open Bluetooth appeared as grey smudges instead of real buttons. -->
    <Style x:Key="ButtonSmall" TargetType="{x:Type ui:Button}" BasedOn="{StaticResource {x:Type ui:Button}}">
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="MinHeight" Value="28" />
        <Setter Property="FontSize" Value="12" />
    </Style>
    <Style x:Key="ButtonMedium" TargetType="{x:Type ui:Button}" BasedOn="{StaticResource {x:Type ui:Button}}">
        <Setter Property="Padding" Value="14,6" />
        <Setter Property="MinHeight" Value="32" />
    </Style>
    <Style x:Key="ButtonPrimaryLarge" TargetType="{x:Type ui:Button}" BasedOn="{StaticResource {x:Type ui:Button}}">
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="Appearance" Value="Primary" />
    </Style>

    <!-- Global defaults -->
    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="FontFamily" Value="{StaticResource UiFontFamily}" />
    </Style>

    <Style TargetType="{x:Type ui:TextBlock}">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="FontFamily" Value="{StaticResource UiFontFamily}" />
    </Style>

</ResourceDictionary>
