<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- My own design tokens (not touching WPF-UI theme system) -->

    <!-- Surface layers we draw cards/panels on -->
    <SolidColorBrush x:Key="SurfaceL0Brush" Color="#1C1C1F" />
    <SolidColorBrush x:Key="SurfaceL1Brush" Color="#232327" />
    <SolidColorBrush x:Key="SurfaceL2Brush" Color="#2B2B30" />
    <SolidColorBrush x:Key="SurfaceL3Brush" Color="#34343A" />

    <SolidColorBrush x:Key="StrokeSubtleBrush" Color="#3A3A42" />
    <SolidColorBrush x:Key="StrokeStrongBrush" Color="#55555F" />

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F2F2F3" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#A8A8B0" />
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="#70707A" />

    <!-- Accent tokens used by OUR widgets (WPF-UI Primary buttons handled by ApplicationAccentColorManager) -->
    <SolidColorBrush x:Key="AccentPrimaryBrush" Color="#6E8CF0" />
    <SolidColorBrush x:Key="AccentSecondaryBrush" Color="#F0B86E" />

    <!-- Semantic -->
    <SolidColorBrush x:Key="SuccessBrush" Color="#4FCB70" />
    <SolidColorBrush x:Key="WarningBrush" Color="#F0B86E" />
    <SolidColorBrush x:Key="ErrorBrush" Color="#ED6A5A" />
    <SolidColorBrush x:Key="InfoBrush" Color="#6E8CF0" />

    <!-- Data viz (RGB = XYZ convention) -->
    <SolidColorBrush x:Key="VizXBrush" Color="#ED6A5A" />
    <SolidColorBrush x:Key="VizYBrush" Color="#4FCB70" />
    <SolidColorBrush x:Key="VizZBrush" Color="#6E8CF0" />
    <SolidColorBrush x:Key="VizBatteryBrush" Color="#F0B86E" />


</ResourceDictionary>
