<Application x:Class="Everything_To_IMU_SlimeVR.UI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:conv="clr-namespace:Everything_To_IMU_SlimeVR.UI.Converters"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Dark" />
                <ui:ControlsDictionary />
                <ResourceDictionary Source="pack://application:,,,/Resources/Theme.Dark.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Resources/Tokens.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Resources/Strings.en.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <conv:BoolToVisibilityConverter x:Key="BoolToVisibility" />
            <conv:ResourceKeyToStringConverter x:Key="ResKeyToString" />
            <conv:EnumDisplayConverter x:Key="EnumDisplay" />
            <conv:ShortcutKeyConverter x:Key="ShortcutKeyParser" />
            <conv:ShortcutDescConverter x:Key="ShortcutDescParser" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
