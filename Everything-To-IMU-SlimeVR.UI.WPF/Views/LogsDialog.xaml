<ui:FluentWindow x:Class="Everything_To_IMU_SlimeVR.UI.Views.LogsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Logs"
        Width="900" Height="620"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True"
        WindowStartupLocation="CenterOwner"
        WindowCornerPreference="Round"
        Icon="pack://application:,,,/Assets/app-256.png">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Logs">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="pack://application:,,,/Assets/app-256.png" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <Grid Grid.Row="1" Margin="16,10,16,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ComboBox x:Name="LogFileCombo" SelectionChanged="LogFileCombo_SelectionChanged"
                      Width="220" HorizontalAlignment="Left" />
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <ui:Button Content="Refresh" Icon="{ui:SymbolIcon ArrowSync24}"
                           Click="Refresh_Click" Margin="0,0,6,0" Padding="10,4" />
                <ui:Button Content="Open folder" Icon="{ui:SymbolIcon FolderOpen24}"
                           Click="OpenFolder_Click" Margin="0,0,6,0" Padding="10,4" />
                <ui:Button Content="Copy all" Icon="{ui:SymbolIcon Copy24}"
                           Click="Copy_Click" Padding="10,4" />
            </StackPanel>
        </Grid>

        <Border Grid.Row="2" Margin="16,0,16,16"
                Background="{DynamicResource SurfaceL1Brush}"
                BorderBrush="{DynamicResource StrokeSubtleBrush}"
                BorderThickness="1" CornerRadius="6">
            <ScrollViewer x:Name="LogScroll" VerticalScrollBarVisibility="Auto" Padding="12,8">
                <TextBox x:Name="LogText" IsReadOnly="True"
                         Background="Transparent" BorderThickness="0"
                         FontFamily="Consolas" FontSize="12"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         TextWrapping="NoWrap" AcceptsReturn="True" />
            </ScrollViewer>
        </Border>
    </Grid>
</ui:FluentWindow>
