<Page x:Class="Everything_To_IMU_SlimeVR.UI.Views.OscPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:vm="clr-namespace:Everything_To_IMU_SlimeVR.UI.ViewModels"
      xmlns:beh="clr-namespace:Everything_To_IMU_SlimeVR.UI.Behaviors"
      Title="OSC">
    <Page.DataContext>
        <vm:OscViewModel />
    </Page.DataContext>

    <ScrollViewer VerticalScrollBarVisibility="Auto" beh:ScrollViewerHelper.CaptureMouseWheel="True">
        <StackPanel Margin="24" MaxWidth="900" HorizontalAlignment="Stretch">
            <ui:TextBlock Text="{DynamicResource Str.Osc.Title}" FontTypography="Title" Margin="0,0,0,16" />

            <ui:TextBlock Text="{DynamicResource Str.Osc.Input}" FontTypography="Subtitle" Margin="0,0,0,8" />
            <Border Padding="16" CornerRadius="8" Margin="0,0,0,20"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                    BorderThickness="1">
                <StackPanel>
                    <ui:TextBlock Text="{DynamicResource Str.Osc.TargetIp}" Opacity="0.7" Margin="0,0,0,4" />
                    <ui:TextBox Text="{Binding IpAddress, UpdateSourceTrigger=PropertyChanged}"
                                PlaceholderText="127.0.0.1" Margin="0,0,0,12" />
                    <ui:TextBlock Text="{DynamicResource Str.Osc.InputPort}" Opacity="0.7" Margin="0,0,0,4" />
                    <ui:TextBox Text="{Binding InputPort, UpdateSourceTrigger=PropertyChanged}"
                                PlaceholderText="9001" Margin="0,0,0,12" />
                    <ui:Button Content="{DynamicResource Str.Osc.Apply}" Icon="{ui:SymbolIcon Save24}"
                               Command="{Binding ApplyCommand}" Appearance="Primary"
                               HorizontalAlignment="Left" />
                </StackPanel>
            </Border>

            <ui:TextBlock Text="{DynamicResource Str.Osc.Outputs}" FontTypography="Subtitle" Margin="0,0,0,8" />
            <Border Padding="16" CornerRadius="8"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                    BorderThickness="1">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <ui:TextBox Text="{Binding NewOutputPort, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="{DynamicResource Str.Osc.NewPortHint}" Width="180" Margin="0,0,8,0" />
                        <ui:Button Content="{DynamicResource Str.Osc.AddOutput}" Icon="{ui:SymbolIcon Add24}"
                                   Command="{Binding AddOutputCommand}" />
                    </StackPanel>
                    <ItemsControl ItemsSource="{Binding OutputPorts}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8" Margin="0,2" CornerRadius="6"
                                        Background="{DynamicResource SubtleFillColorSecondaryBrush}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding}" VerticalAlignment="Center" FontFamily="Consolas" />
                                        <ui:Button Grid.Column="1" Icon="{ui:SymbolIcon Delete24}"
                                                   Command="{Binding DataContext.RemoveOutputCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                   CommandParameter="{Binding}" Padding="6,2" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <ui:InfoBar Title="OSC" Message="{Binding StatusMessage}"
                        IsOpen="{Binding HasStatus}" Severity="Informational"
                        Margin="0,16,0,0" />
        </StackPanel>
    </ScrollViewer>
</Page>
