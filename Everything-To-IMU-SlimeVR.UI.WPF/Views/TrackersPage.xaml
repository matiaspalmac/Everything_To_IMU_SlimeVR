<Page x:Class="Everything_To_IMU_SlimeVR.UI.Views.TrackersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:vm="clr-namespace:Everything_To_IMU_SlimeVR.UI.ViewModels"
      xmlns:beh="clr-namespace:Everything_To_IMU_SlimeVR.UI.Behaviors"
      Title="Trackers">
    <Page.DataContext>
        <vm:TrackersViewModel />
    </Page.DataContext>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                  beh:ScrollViewerHelper.CaptureMouseWheel="True">
    <Grid Margin="24" MinHeight="420">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*" MinWidth="260" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="2*" MinWidth="260" />
        </Grid.ColumnDefinitions>

        <!-- Left: devices -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,12">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <ui:TextBlock Text="{DynamicResource Str.Trackers.Devices}" FontTypography="Title" />
                    <ui:TextBlock Text="{Binding Trackers.Count, StringFormat=' ({0})'}"
                                  FontTypography="Title"
                                  Foreground="{DynamicResource TextTertiaryBrush}" />
                </StackPanel>
                <Border BorderBrush="{DynamicResource InfoBrush}" BorderThickness="1"
                        Background="{DynamicResource SurfaceL2Brush}"
                        CornerRadius="6" Padding="12,10">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsEmpty}" Value="True" />
                                        <Condition Binding="{Binding IsHintOpen}" Value="True" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible" />
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:SymbolIcon Grid.Column="0" Symbol="Info24"
                                       Foreground="{DynamicResource InfoBrush}"
                                       VerticalAlignment="Top" Margin="0,2,10,0" />
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="{DynamicResource Str.Trackers.HintTitle}" FontWeight="SemiBold" Margin="0,0,0,4" />
                            <TextBlock Text="{DynamicResource Str.Trackers.HintMsg}" TextWrapping="Wrap"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                        </StackPanel>
                        <ui:Button Grid.Column="2" Content="{DynamicResource Str.Trackers.OpenBluetooth}"
                                   Command="{Binding OpenWindowsBluetoothCommand}"
                                   Style="{StaticResource ButtonSmall}"
                                   VerticalAlignment="Center" Margin="12,0,6,0" />
                        <ui:Button Grid.Column="3" Icon="{ui:SymbolIcon Dismiss24}"
                                   Command="{Binding DismissHintCommand}"
                                   Style="{StaticResource ButtonSmall}"
                                   Padding="6,4" VerticalAlignment="Top" />
                    </Grid>
                </Border>
            </StackPanel>

            <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="0">
                <DataGrid ItemsSource="{Binding Trackers}"
                          SelectedItem="{Binding SelectedTracker}"
                          AutoGenerateColumns="False"
                          HeadersVisibility="Column"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserReorderColumns="False"
                          CanUserResizeRows="False"
                          IsReadOnly="True"
                          GridLinesVisibility="Horizontal"
                          RowHeight="32"
                          ColumnHeaderHeight="36"
                          FontSize="12"
                          BorderThickness="0"
                          Background="Transparent"
                          RowBackground="Transparent"
                          Foreground="{DynamicResource TextPrimaryBrush}"
                          HorizontalScrollBarVisibility="Auto">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
                            <Setter Property="Padding" Value="12,0" />
                            <Setter Property="FontSize" Value="12" />
                            <Setter Property="VerticalContentAlignment" Value="Center" />
                            <Setter Property="HorizontalContentAlignment" Value="Left" />
                            <Setter Property="BorderBrush" Value="{DynamicResource StrokeSubtleBrush}" />
                            <Setter Property="BorderThickness" Value="0,0,0,1" />
                            <Setter Property="MinHeight" Value="36" />
                        </Style>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="Transparent" />
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource SurfaceL3Brush}" />
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource SurfaceL3Brush}" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="{DynamicResource Str.Trackers.Col.Type}" Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="12,0">
                                        <ui:SymbolIcon Symbol="{Binding TypeIcon}" FontSize="18" Margin="0,0,8,0"
                                                       Foreground="{DynamicResource AccentPrimaryBrush}" />
                                        <TextBlock Text="{Binding TypeLabel}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="{DynamicResource Str.Trackers.Col.Id}" Binding="{Binding Id}" Width="*" />
                        <DataGridTemplateColumn Header="{DynamicResource Str.Trackers.Col.Ready}" Width="130">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="8,0" VerticalAlignment="Center">
                                        <Ellipse Width="8" Height="8" Margin="0,0,8,0" Fill="{Binding StatusBrush}" />
                                        <TextBlock Text="{Binding StatusText}" FontSize="12" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Battery" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <ui:SymbolIcon Symbol="Battery1024" FontSize="14" Margin="0,0,4,0"
                                                       Foreground="{Binding BatteryBrush}"
                                                       Visibility="{Binding HasBattery, Converter={StaticResource BoolToVisibility}}" />
                                        <TextBlock Text="{Binding BatteryText}" FontFamily="Consolas" FontSize="11"
                                                   Foreground="{Binding BatteryBrush}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Rate" Width="70">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding HzText}" FontFamily="Consolas" FontSize="11"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Mount" Width="60">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding MountYawText}" FontFamily="Consolas" FontSize="11"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="{DynamicResource Str.Trackers.Col.Imu}" Width="60">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ui:SymbolIcon HorizontalAlignment="Center">
                                        <ui:SymbolIcon.Style>
                                            <Style TargetType="ui:SymbolIcon">
                                                <Setter Property="Symbol" Value="Dismiss24" />
                                                <Setter Property="Foreground" Value="{DynamicResource TextTertiaryBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SupportsImu}" Value="True">
                                                        <Setter Property="Symbol" Value="Checkmark24" />
                                                        <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ui:SymbolIcon.Style>
                                    </ui:SymbolIcon>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="{DynamicResource Str.Trackers.Col.Haptics}" Width="70">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ui:SymbolIcon HorizontalAlignment="Center">
                                        <ui:SymbolIcon.Style>
                                            <Style TargetType="ui:SymbolIcon">
                                                <Setter Property="Symbol" Value="Dismiss24" />
                                                <Setter Property="Foreground" Value="{DynamicResource TextTertiaryBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SupportsHaptics}" Value="True">
                                                        <Setter Property="Symbol" Value="Checkmark24" />
                                                        <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ui:SymbolIcon.Style>
                                    </ui:SymbolIcon>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Reset/Recalibrate controls removed: SlimeVR dashboard owns calibration state.
                 Use the SlimeVR Server window for Reset Full / Yaw / Mounting. -->
        </Grid>

        <!-- Right: settings panel -->
        <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto" Padding="0,0,4,0">
            <StackPanel>
                <ui:TextBlock Text="{DynamicResource Str.Trackers.Selected}" FontTypography="Title" Margin="0,0,0,12" />

                <StackPanel Visibility="{Binding HasSelection, Converter={StaticResource BoolToVisibility}}">
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="{Binding SelectedTracker.Id}" FontWeight="SemiBold" FontSize="14" />
                            <TextBlock Text="{Binding SelectedTracker.TypeLabel}"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12"
                            Visibility="{Binding SelectedTracker.SupportsImu, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                <TextBlock Text="{DynamicResource Str.Trackers.PrimaryYaw}"
                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                                <ui:SymbolIcon Symbol="Info24" FontSize="14" Margin="6,0,0,0"
                                               Foreground="{DynamicResource TextTertiaryBrush}"
                                               ToolTip="{DynamicResource Str.Trackers.YawTooltip}" />
                            </StackPanel>
                            <TextBlock Text="{DynamicResource Str.Trackers.PrimaryYawDesc}"
                                       FontSize="11" TextWrapping="Wrap"
                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                       Margin="0,0,0,6" />
                            <ComboBox ItemsSource="{Binding YawSources}"
                                      SelectedItem="{Binding SelectedYawSource}"
                                      HorizontalAlignment="Stretch" Margin="0,0,0,12">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Converter={StaticResource EnumDisplay}}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <TextBlock Text="{DynamicResource Str.Trackers.ExtensionYaw}"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,2" />
                            <TextBlock Text="{DynamicResource Str.Trackers.ExtensionYawDesc}"
                                       FontSize="11" TextWrapping="Wrap"
                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                       Margin="0,0,0,6" />
                            <ComboBox ItemsSource="{Binding YawSources}"
                                      SelectedItem="{Binding SelectedExtensionYawSource}"
                                      HorizontalAlignment="Stretch">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Converter={StaticResource EnumDisplay}}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12"
                            Visibility="{Binding SelectedTracker.SupportsHaptics, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Str.Trackers.HapticNode}"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,2" />
                            <TextBlock Text="{DynamicResource Str.Trackers.HapticNodeDesc}"
                                       FontSize="11" TextWrapping="Wrap"
                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                       Margin="0,0,0,6" />
                            <ComboBox ItemsSource="{Binding HapticNodes}"
                                      SelectedItem="{Binding SelectedHapticNode}"
                                      HorizontalAlignment="Stretch">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Converter={StaticResource EnumDisplay}}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12"
                            Visibility="{Binding SelectedTracker.SupportsImu, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel>
                            <TextBlock Text="Mount rotation"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,2" />
                            <TextBlock Text="Click to cycle 0° → 90° → 180° → 270°. Persists per controller MAC across sessions."
                                       FontSize="11" TextWrapping="Wrap"
                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                       Margin="0,0,0,6" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ui:Button Grid.Column="0" Content="Rotate +90°"
                                           Icon="{ui:SymbolIcon ArrowRotateClockwise24}"
                                           Command="{Binding RotateMountCommand}"
                                           HorizontalAlignment="Stretch" />
                                <TextBlock Grid.Column="2" Text="{Binding SelectedMountYawText}"
                                           FontFamily="Consolas" FontSize="14" VerticalAlignment="Center"
                                           Foreground="{DynamicResource AccentPrimaryBrush}"
                                           Margin="8,0,0,0" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <ui:Button Grid.Column="0" Content="{DynamicResource Str.Trackers.Identify}"
                                   Icon="{ui:SymbolIcon Flash24}"
                                   Command="{Binding IdentifyCommand}"
                                   HorizontalAlignment="Stretch"
                                   Visibility="{Binding SelectedTracker.SupportsHaptics, Converter={StaticResource BoolToVisibility}}" />
                        <ui:Button Grid.Column="2" Content="{DynamicResource Str.Trackers.Rediscover}"
                                   Icon="{ui:SymbolIcon Search24}"
                                   Command="{Binding RediscoverCommand}"
                                   HorizontalAlignment="Stretch"
                                   Visibility="{Binding SelectedTracker.SupportsImu, Converter={StaticResource BoolToVisibility}}" />
                    </Grid>
                    <ui:Button Content="{DynamicResource Str.Trackers.Calibrate}"
                               Icon="{ui:SymbolIcon Target24}"
                               Command="{Binding RecalibrateCommand}"
                               Appearance="Primary"
                               HorizontalAlignment="Stretch" Margin="0,0,0,8"
                               Visibility="{Binding SelectedTracker.SupportsImu, Converter={StaticResource BoolToVisibility}}" />
                    <ui:Button Content="{DynamicResource Str.Trackers.CalibrateHaptics}"
                               Icon="{ui:SymbolIcon Pulse24}"
                               Command="{Binding CalibrateHapticsCommand}"
                               HorizontalAlignment="Stretch"
                               Visibility="{Binding SelectedTracker.SupportsHaptics, Converter={StaticResource BoolToVisibility}}" />
                </StackPanel>

                <Border Style="{StaticResource CardStyle}"
                        Visibility="{Binding HasSelection, Converter={StaticResource BoolToVisibility}, ConverterParameter=Inverse}">
                    <ui:TextBlock Text="{DynamicResource Str.Trackers.NoSelection}"
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  TextWrapping="Wrap" />
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Empty state overlay -->
        <Grid Grid.Column="0"
              Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,0,64">
                <ui:SymbolIcon Symbol="PlugDisconnected24" FontSize="40"
                               Foreground="{DynamicResource TextTertiaryBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,12" />
                <ui:TextBlock Text="{DynamicResource Str.Trackers.EmptyTitle}"
                              FontTypography="Subtitle"
                              Foreground="{DynamicResource TextSecondaryBrush}"
                              HorizontalAlignment="Center" Margin="0,0,0,4" />
                <ui:TextBlock Text="{DynamicResource Str.Trackers.EmptyHint}"
                              Foreground="{DynamicResource TextTertiaryBrush}"
                              HorizontalAlignment="Center" Margin="0,0,0,14" />
                <ui:Button Content="{DynamicResource Str.Trackers.RescanDevices}"
                           Icon="{ui:SymbolIcon ArrowSync24}"
                           Command="{Binding RescanDevicesCommand}"
                           Style="{StaticResource ButtonMedium}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Grid>
    </Grid>
    </ScrollViewer>
</Page>
