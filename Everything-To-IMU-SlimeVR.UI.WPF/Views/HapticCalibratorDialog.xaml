<ui:FluentWindow x:Class="Everything_To_IMU_SlimeVR.UI.Views.HapticCalibratorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Haptic Calibrator"
        Width="520" Height="280"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True"
        WindowStartupLocation="CenterOwner"
        WindowCornerPreference="Round"
        Icon="pack://application:,,,/Assets/app-256.png">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="{DynamicResource Str.Haptics.CalibratorTitle}">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="pack://application:,,,/Assets/app-256.png" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <StackPanel Grid.Row="1" Margin="24,12,24,24">
            <ui:TextBlock Text="{DynamicResource Str.Haptics.CalibratorBody}" Opacity="0.7" TextWrapping="Wrap" Margin="0,0,0,12" />

            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <ui:TextBlock Text="{DynamicResource Str.Haptics.Intensity}" />
                <ui:TextBlock Text=": " />
                <ui:TextBlock Text="{Binding ElementName=IntensitySlider, Path=Value, StringFormat=F3}"
                              FontWeight="SemiBold" />
            </StackPanel>
            <Slider x:Name="IntensitySlider" Minimum="0" Maximum="1" Value="0"
                    TickFrequency="0.05" IsSnapToTickEnabled="False"
                    ValueChanged="IntensitySlider_ValueChanged" Margin="0,0,0,24" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button Content="{DynamicResource Str.Common.Close}" Click="Close_Click" Margin="0,0,0,0" />
            </StackPanel>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
