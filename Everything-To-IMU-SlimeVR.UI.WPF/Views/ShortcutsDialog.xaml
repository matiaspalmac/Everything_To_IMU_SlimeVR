<ui:FluentWindow x:Class="Everything_To_IMU_SlimeVR.UI.Views.ShortcutsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Keyboard shortcuts"
        Width="480" Height="440"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True"
        WindowStartupLocation="CenterOwner"
        WindowCornerPreference="Round"
        Icon="pack://application:,,,/Assets/app-256.png">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Keyboard shortcuts">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="pack://application:,,,/Assets/app-256.png" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <ScrollViewer Grid.Row="1" Padding="24,12,24,24" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <ItemsControl>
                    <ItemsControl.ItemsSource>
                        <x:Array Type="sys:String" xmlns:sys="clr-namespace:System;assembly=System.Runtime">
                            <sys:String>F1|Show this help</sys:String>
                            <sys:String>Ctrl+L|Launch SteamVR (when ready)</sys:String>
                            <sys:String>Ctrl+R|Rescan devices</sys:String>
                            <sys:String>Ctrl+K|Calibrate selected tracker</sys:String>
                            <sys:String>Ctrl+Shift+K|Recalibrate all trackers</sys:String>
                            <sys:String>Ctrl+D|Open SlimeVR dashboard</sys:String>
                            <sys:String>Ctrl+,|Open Settings</sys:String>
                            <sys:String>Space|Pause/resume Debug chart</sys:String>
                            <sys:String>Esc|Minimize to tray</sys:String>
                        </x:Array>
                    </ItemsControl.ItemsSource>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="{DynamicResource SurfaceL3Brush}"
                                        CornerRadius="4" Padding="8,2" HorizontalAlignment="Left">
                                    <TextBlock FontFamily="Consolas" FontSize="12"
                                               Text="{Binding Converter={StaticResource ShortcutKeyParser}}" />
                                </Border>
                                <TextBlock Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0"
                                           Text="{Binding Converter={StaticResource ShortcutDescParser}}"
                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</ui:FluentWindow>
