<Page x:Class="Everything_To_IMU_SlimeVR.UI.Views.CameraSettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:vm="clr-namespace:Everything_To_IMU_SlimeVR.UI.ViewModels"
      xmlns:beh="clr-namespace:Everything_To_IMU_SlimeVR.UI.Behaviors"
      Title="Camera">
    <Page.DataContext>
        <vm:CameraSettingsViewModel />
    </Page.DataContext>

    <ScrollViewer VerticalScrollBarVisibility="Auto" beh:ScrollViewerHelper.CaptureMouseWheel="True">
        <StackPanel Margin="24" MaxWidth="1100" HorizontalAlignment="Stretch">

            <ui:TextBlock Text="Webcam pose source" FontTypography="Title" Margin="0,0,0,4" />
            <TextBlock Text="Turn a webcam into 6 SlimeVR full-body trackers (HIP, CHEST, both upper legs, both feet). Hands and head stay on Quest controllers / HMD."
                       TextWrapping="Wrap" Opacity="0.7" Margin="0,0,0,16" />

            <Border Padding="16" CornerRadius="8" Margin="0,0,0,16"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                    BorderThickness="1">
                <StackPanel>
                    <ui:TextBlock Text="Pipeline" FontTypography="Subtitle" Margin="0,0,0,12" />
                    <ui:ToggleSwitch Content="Enable webcam pose tracking"
                                     IsChecked="{Binding Enabled}" Margin="0,0,0,8" />
                    <TextBlock Text="{Binding StatusMessage}" Opacity="0.75" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Padding="16" CornerRadius="8" Margin="0,0,0,16"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                    BorderThickness="1">
                <StackPanel>
                    <ui:TextBlock Text="Camera" FontTypography="Subtitle" Margin="0,0,0,12" />

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Camera" VerticalAlignment="Center" Margin="0,0,12,0" />
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding AvailableDevices}"
                                  SelectedValue="{Binding DeviceIndex, Mode=TwoWay}"
                                  SelectedValuePath="Index"
                                  DisplayMemberPath="FriendlyName"
                                  HorizontalAlignment="Stretch" />
                        <ui:Button Grid.Column="2"
                                   Icon="{ui:SymbolIcon ArrowSync24}"
                                   Content="Rescan"
                                   Margin="8,0,0,0"
                                   Command="{Binding RefreshDevicesCommand}"
                                   IsEnabled="{Binding CanRescan}" />
                    </Grid>

                    <TextBlock Text="Resolution / FPS preset" Opacity="0.7" Margin="0,0,0,2" />
                    <ComboBox ItemsSource="{Binding AvailablePresets}"
                              SelectedItem="{Binding SelectedPreset, Mode=TwoWay}"
                              DisplayMemberPath="Label"
                              HorizontalAlignment="Stretch"
                              Margin="0,0,0,8" />

                    <Grid Margin="0,0,0,8" Visibility="{Binding IsCustomPreset, Converter={StaticResource BoolToVisibility}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="Width" Opacity="0.7" Margin="0,0,0,2" />
                            <ui:NumberBox Value="{Binding CaptureWidth, Mode=TwoWay}" Minimum="320" Maximum="3840" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="0,0,8,0">
                            <TextBlock Text="Height" Opacity="0.7" Margin="0,0,0,2" />
                            <ui:NumberBox Value="{Binding CaptureHeight, Mode=TwoWay}" Minimum="240" Maximum="2160" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="FPS" Opacity="0.7" Margin="0,0,0,2" />
                            <ui:NumberBox Value="{Binding CaptureFps, Mode=TwoWay}" Minimum="5" Maximum="120" />
                        </StackPanel>
                    </Grid>

                    <Border Background="{DynamicResource AccentFillColorTertiaryBrush}"
                            CornerRadius="4" Padding="10,8" Margin="0,0,0,8"
                            Visibility="{Binding IsVirtualCameraSelected, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}">
                            <Run Text="Virtual camera detected." FontWeight="SemiBold" />
                            <Run Text=" Resolution and FPS are set by OBS / NDI / virtual camera source, not by this app. Configure them in OBS Studio's Settings → Video instead." />
                        </TextBlock>
                    </Border>

                    <ui:ToggleSwitch Content="Mirror preview (does not affect tracking)"
                                     IsChecked="{Binding MirrorPreview}" />
                </StackPanel>
            </Border>

            <Border Padding="16" CornerRadius="8" Margin="0,0,0,16"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                    BorderThickness="1">
                <StackPanel>
                    <ui:TextBlock Text="Calibration" FontTypography="Subtitle" Margin="0,0,0,12" />
                    <TextBlock Text="Stand facing the camera, full body in frame. Stay still 1.5s for auto T-pose capture, or press the button below to retry."
                               Opacity="0.7" TextWrapping="Wrap" Margin="0,0,0,12" />
                    <StackPanel Orientation="Horizontal">
                        <ui:Button Content="Capture T-pose"
                                   Icon="{ui:SymbolIcon Person24}"
                                   Command="{Binding CaptureTPoseCommand}"
                                   Margin="0,0,8,0" />
                        <ui:Button Content="Reset calibration"
                                   Icon="{ui:SymbolIcon ArrowReset24}"
                                   Command="{Binding ResetCalibrationCommand}" />
                        <TextBlock Text="✓ Calibrated"
                                   Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Margin="16,0,0,0"
                                   Visibility="{Binding Calibrated, Converter={StaticResource BoolToVisibility}}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Padding="16" CornerRadius="8" Margin="0,0,0,16"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                    BorderThickness="1">
                <StackPanel>
                    <ui:TextBlock Text="Live preview" FontTypography="Subtitle" Margin="0,0,0,12" />
                    <Border Background="#202020" CornerRadius="4" MinHeight="280">
                        <Image Source="{Binding PreviewBitmap}" Stretch="Uniform" StretchDirection="DownOnly" />
                    </Border>
                    <TextBlock Text="{Binding CaptureFormat}" Opacity="0.6" Margin="0,8,0,0" />
                </StackPanel>
            </Border>

            <Border Padding="16" CornerRadius="8"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                    BorderThickness="1">
                <StackPanel>
                    <ui:TextBlock Text="Diagnostics" FontTypography="Subtitle" Margin="0,0,0,12" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Live FPS: " Opacity="0.6" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding LiveFps, StringFormat={}{0:0.#}}" FontFamily="Consolas" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Last inference: " Opacity="0.6" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding InferenceMs, StringFormat={}{0:0.0} ms}" FontFamily="Consolas" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Frames processed: " Opacity="0.6" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding FramesProcessed}" FontFamily="Consolas" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Frames dropped: " Opacity="0.6" />
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding FramesDropped}" FontFamily="Consolas" />

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Model layout: " Opacity="0.6" />
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding ModelLayout}" FontFamily="Consolas" />

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="World 3D output: " Opacity="0.6" />
                        <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding HasWorldLandmarks}" FontFamily="Consolas" />
                    </Grid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
