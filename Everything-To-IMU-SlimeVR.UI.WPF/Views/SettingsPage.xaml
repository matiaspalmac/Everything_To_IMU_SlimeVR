<Page x:Class="Everything_To_IMU_SlimeVR.UI.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:vm="clr-namespace:Everything_To_IMU_SlimeVR.UI.ViewModels"
      xmlns:beh="clr-namespace:Everything_To_IMU_SlimeVR.UI.Behaviors"
      Title="Settings">
    <Page.DataContext>
        <vm:SettingsViewModel />
    </Page.DataContext>

    <ScrollViewer VerticalScrollBarVisibility="Auto" beh:ScrollViewerHelper.CaptureMouseWheel="True">
        <StackPanel Margin="24" MaxWidth="900" HorizontalAlignment="Stretch">
            <ui:TextBlock Text="{DynamicResource Str.Settings.Title}" FontTypography="Title" Margin="0,0,0,16" />

            <Border Padding="16" CornerRadius="8" Margin="0,0,0,16"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                    BorderThickness="1">
                <StackPanel>
                    <ui:TextBlock Text="{DynamicResource Str.Settings.PollingRates}" FontTypography="Subtitle" Margin="0,0,0,12" />

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="{DynamicResource Str.Settings.Controllers}" />
                        <TextBlock Text=": " />
                        <TextBlock Text="{Binding PollingRate}" FontWeight="SemiBold" />
                        <TextBlock Text=" ms" />
                    </StackPanel>
                    <Slider Minimum="1" Maximum="32" Value="{Binding PollingRate}"
                            TickFrequency="1" IsSnapToTickEnabled="True" Margin="0,0,0,16" />

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="{DynamicResource Str.Settings.Wiimote}" />
                        <TextBlock Text=": " />
                        <TextBlock Text="{Binding WiiPollingRate}" FontWeight="SemiBold" />
                        <TextBlock Text=" ms" />
                    </StackPanel>
                    <Slider Minimum="8" Maximum="128" Value="{Binding WiiPollingRate}"
                            TickFrequency="1" IsSnapToTickEnabled="True" />
                </StackPanel>
            </Border>

            <Border Padding="16" CornerRadius="8" Margin="0,0,0,16"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                    BorderThickness="1">
                <StackPanel>
                    <ui:TextBlock Text="{DynamicResource Str.Settings.Tracking}" FontTypography="Subtitle" Margin="0,0,0,12" />
                    <ui:ToggleSwitch Content="{DynamicResource Str.Settings.SimulateThighs}"
                                     IsChecked="{Binding SimulateThighs}" Margin="0,0,0,8" />
                    <ui:ToggleSwitch Content="{DynamicResource Str.Settings.AudioHaptics}"
                                     IsChecked="{Binding AudioHapticsActive}" />
                </StackPanel>
            </Border>

            <Border Padding="16" CornerRadius="8"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                    BorderThickness="1">
                <StackPanel>
                    <ui:TextBlock Text="{DynamicResource Str.Settings.Appearance}" FontTypography="Subtitle" Margin="0,0,0,12" />

                    <ui:TextBlock Text="{DynamicResource Str.Settings.Theme}" Opacity="0.7" Margin="0,0,0,4" />
                    <ComboBox ItemsSource="{Binding Themes}"
                              SelectedItem="{Binding SelectedTheme}"
                              HorizontalAlignment="Stretch" Margin="0,0,0,12">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayResourceKey, Converter={StaticResource ResKeyToString}}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <ui:TextBlock Text="{DynamicResource Str.Settings.Language}" Opacity="0.7" Margin="0,0,0,4" />
                    <ComboBox ItemsSource="{Binding Languages}"
                              SelectedItem="{Binding SelectedLanguage}"
                              DisplayMemberPath="DisplayName"
                              HorizontalAlignment="Stretch" />
                </StackPanel>
            </Border>

            <Border Padding="16" CornerRadius="8" Margin="0,16,0,0"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                    BorderThickness="1">
                <StackPanel>
                    <ui:TextBlock Text="{DynamicResource Str.Settings.About}" FontTypography="Subtitle" Margin="0,0,0,12" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Image Source="pack://application:,,,/Assets/app-256.png" Width="48" Height="48" Margin="0,0,12,0" />
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Everything To IMU SlimeVR" FontWeight="SemiBold" FontSize="15" />
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{DynamicResource Str.Settings.Version}" Opacity="0.6" />
                                <TextBlock Text=" " />
                                <TextBlock Text="{Binding AppVersion}" Opacity="0.8" FontFamily="Consolas" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                    <TextBlock Text="{DynamicResource Str.Settings.AboutLine1}" TextWrapping="Wrap" Opacity="0.8" Margin="0,4,0,12" />
                    <StackPanel Orientation="Horizontal">
                        <ui:HyperlinkButton Content="{DynamicResource Str.Settings.Repository}"
                                            Icon="{ui:SymbolIcon Link24}"
                                            NavigateUri="https://github.com/Sebane1/Everything_To_IMU_SlimeVR"
                                            Margin="0,0,8,0" />
                        <ui:Button Content="View logs"
                                   Icon="{ui:SymbolIcon DocumentBulletList24}"
                                   Command="{Binding OpenLogsCommand}"
                                   Margin="0,0,8,0" />
                        <ui:Button Content="{DynamicResource Str.Settings.OpenLogs}"
                                   Icon="{ui:SymbolIcon FolderOpen24}"
                                   Command="{Binding OpenAppFolderCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
