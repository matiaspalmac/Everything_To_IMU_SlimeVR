<Page x:Class="Everything_To_IMU_SlimeVR.UI.Views.HapticsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:vm="clr-namespace:Everything_To_IMU_SlimeVR.UI.ViewModels"
      xmlns:beh="clr-namespace:Everything_To_IMU_SlimeVR.UI.Behaviors"
      Title="Haptics">
    <Page.DataContext>
        <vm:HapticsViewModel />
    </Page.DataContext>

    <ScrollViewer VerticalScrollBarVisibility="Auto" beh:ScrollViewerHelper.CaptureMouseWheel="True">
        <StackPanel Margin="24" MaxWidth="900" HorizontalAlignment="Stretch">
            <ui:TextBlock Text="{DynamicResource Str.Haptics.Title}" FontTypography="Title" Margin="0,0,0,16" />

            <ui:TextBlock Text="{DynamicResource Str.Haptics.RemoteDevices}" FontTypography="Subtitle" Margin="0,0,0,8" />
            <Border Padding="16" CornerRadius="8" Margin="0,0,0,20"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                    BorderThickness="1">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <ui:TextBox Text="{Binding NewIp, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="{DynamicResource Str.Haptics.IpHint}" Width="240" Margin="0,0,8,0" />
                        <ui:Button Content="{DynamicResource Str.Haptics.Add}" Icon="{ui:SymbolIcon Add24}" Command="{Binding AddCommand}" />
                    </StackPanel>
                    <ItemsControl ItemsSource="{Binding HapticDevices}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8" Margin="0,2" CornerRadius="6"
                                        Background="{DynamicResource SubtleFillColorSecondaryBrush}">
                                    <TextBlock Text="{Binding}" FontFamily="Consolas" />
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <ui:TextBlock Text="{DynamicResource Str.Haptics.Testing}" FontTypography="Subtitle" Margin="0,0,0,8" />
            <Border Padding="16" CornerRadius="8"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                    BorderThickness="1">
                <StackPanel Orientation="Horizontal">
                    <ui:Button Content="{DynamicResource Str.Haptics.PulseAll}" Icon="{ui:SymbolIcon Flash24}"
                               Command="{Binding TestPulseCommand}" Margin="0,0,8,0" />
                    <ui:Button Content="{DynamicResource Str.Haptics.PlayMidi}" Icon="{ui:SymbolIcon MusicNote124}"
                               Command="{Binding LoadMidiCommand}" />
                </StackPanel>
            </Border>

            <ui:InfoBar Title="Haptics" Message="{Binding StatusMessage}"
                        IsOpen="{Binding HasStatus}" Severity="Informational"
                        Margin="0,16,0,0" />
        </StackPanel>
    </ScrollViewer>
</Page>
